{
  "name": "@aprovan/main",
  "version": "0.1.0",
  "description": "Shared Aprovan environment loading and utilities",
  "type": "module",
  "bin": {
    "aprovan-env": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.848.0",
    "dotenv": "^17.2.0"
  },
  "devDependencies": {
    "@aprovan/eslint-config": "workspace:*",
    "@aprovan/tsconfig": "workspace:*",
    "@types/node": "^24.0.13",
    "eslint": "^9.31.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
