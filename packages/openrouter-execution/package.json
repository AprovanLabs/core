  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@aprovan/eslint-config": "workspace:*",
    "@aprovan/tsconfig": "workspace:*",
    "@aprovan/vitest-config": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}