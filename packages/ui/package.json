{
  "name": "@aprovan/ui",
  "version": "0.2.1",
  "description": "Aprovan design tokens and React primitives",
  "type": "module",
  "sideEffects": [
    "./dist/theme.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./gateway": {
      "types": "./dist/gateway/index.d.ts",
      "import": "./dist/gateway/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp src/theme.css dist/theme.css",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "oidc-client-ts": "^3.1.0",
    "radix-ui": "^1.4.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@aprovan/eslint-config": "workspace:*",
    "@aprovan/tsconfig": "workspace:*",
    "@types/react": "^19.1.8",
    "eslint": "^9.31.0",
    "react": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
