<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://apple.com">
<plist version="1.0">
    <dict>
        <key>Label</key>
        <string>com.cursor.agent</string>
        <key>ProgramArguments</key>
        <array>
            <string>/bin/zsh</string>
            <string>-c</string>
            <string>cd "$HOME" && /opt/homebrew/bin/cursor agent worker start</string>
        </array>
        <key>RunAtLoad</key>
        <true />
        <key>KeepAlive</key>
        <true />
        <key>StandardOutPath</key>
        <string>/tmp/com.cursor.agent.out.log</string>
        <key>StandardErrorPath</key>
        <string>/tmp/com.cursor.agent.err.log</string>
    </dict>
</plist>